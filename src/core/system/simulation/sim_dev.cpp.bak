/******************************************************************************
 * @file  sim_dev.cpp
 * @brief ComBus simulation device — lifecycle and dispatch loop.
 *
 * @details This file owns only the array-level API (`sim_dev_init` /
 *   `sim_dev_update`).  All signal-processing logic lives in the dedicated
 *   behaviour modules:
 *     - sim_traction.cpp — traction inertia + 5-state drive FSM.
 *     - (future) sim_light.cpp — light envelope / xenon / flicker.
 *
 *   Adding a new behaviour = create a new `*_update(SimDev*, ComBus&, const SimDevCtx&)`
 *   function, assign its address to `SimDev::behaviorFn` in the machine config.
 *   No change needed in this file.
 *****************************************************************************/

#include "sim_dev.h"

#include "core/system/combus/combus_res.h"   // CbusNeutral


// =============================================================================
// 1. LIFECYCLE
// =============================================================================

void sim_dev_init(SimDev* devs, uint8_t count)
{
    // Each behaviour self-inits on first call (checks its own zero-state).
    // Nothing to do here at the array level — kept for symmetry with dc_dev_init
    // and as a hook if a future behaviour requires pre-flight setup.
    (void)devs;
    (void)count;
}


// =============================================================================
// 2. DISPATCH LOOP
// =============================================================================

void sim_dev_update(SimDev* devs, uint8_t count, ComBus& bus, const SimDevCtx& ctx)
{
    // Per-cycle reset: clear isDrived on all SimDev output channels so that
    // the clone guard (below) only fires for a duplicate outCh within THIS cycle
    // — not for channels written in a previous cycle.
    for (uint8_t i = 0; i < count; i++)
        bus.analogBus[static_cast<uint8_t>(devs[i].outCh)].isDrived = false;

    for (uint8_t i = 0; i < count; i++)
    {
        SimDev* dev = &devs[i];

        // Clone guard: skip if an earlier SimDev already wrote this channel this cycle.
        if (bus.analogBus[static_cast<uint8_t>(dev->outCh)].isDrived)
            continue;

        if (dev->behaviorFn != nullptr)
            dev->behaviorFn(dev, bus, ctx);
    }
}

void sim_dev_update(SimDev* devs, uint8_t count, ComBus& bus)
{
    const SimDevCtx ctx {
        .engineOn       = bus.keyOn,
        .neutralGear    = false,
        .failSafe       = false,
        .lowRange       = false,
        .speedLimit     = 0u,
        .globalAccelPct = 100u,
    };
    sim_dev_update(devs, count, bus, ctx);
}

// EOF sim_dev.cpp

