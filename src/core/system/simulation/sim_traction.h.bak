/******************************************************************************
 * @file  sim_traction.h
 * @brief SimDev behaviour — traction inertia and 5-state drive FSM.
 *
 * @details `sim_traction_update()` implements the traction behaviour family
 *   for SimDev:
 *   - Gear-dependent inertia ramp — reads `TRACTION_RAMP_BUS` (written by a
 *     preceding `sim_gear` SimDev); falls back to `SimTractionCfg::defaultRampTime`
 *     when no sim_gear is present.  `GearShiftProfile` is the single source of
 *     truth for per-gear ramp values (via `rampTime[]` in the profile).
 *   - 5-state drive FSM: STAND / FWD / BRK_FWD / REV / BRK_REV.
 *   - Gear-sync throttle correction for manual gearboxes (shift detected via
 *     `SimDev::gearCh` — gear delta vs. previous cycle, no external flags).
 *   - Clutch-engaging gain at low speed (prevents clutch slip).
 *   - Speed cap and battery-low protection.
 *
 *   Gear is read directly from the ComBus via `SimDev::gearCh` (written by a
 *   preceding `sim_gear` SimDev).  If `gearCh` is absent, gear defaults to 1.
 *   This replaces the former `ctx.selectedGear` / `ctx.gearUpShiftPulse` / 
 *   `ctx.gearDownShiftPulse` / `ctx.automatic` / `ctx.doubleClutch` fields.
 *
 *   Assign this function to `SimDev::behaviorFn` in the machine config:
 *   @code
 *     SimDev kMyDev = { ..., .behaviorFn = sim_traction_update };
 *   @endcode
 *
 *   The function writes the processed inertial position to `dev->outCh`
 *   (analog) and the optional digital flags (`outRevCh`, `outBrakeCh`,
 *   `outDriveCh`).  It never touches hardware — all outputs are ComBus values
 *   read by the downstream hardware device.
 *****************************************************************************/
#pragma once

#include <struct/machines_struct.h>   // SimDev, SimTractionCfg, SimTractionState, SimBehaviorFn
#include <struct/combus_struct.h>     // ComBus

// Forward declaration — full type defined in sim_dev.h.
struct SimDevCtx;


// =============================================================================
// 1. PUBLIC API
// =============================================================================

/**
 * @brief Traction inertia behaviour — assigned to `SimDev::behaviorFn`.
 *
 * @details Matches the `SimBehaviorFn` signature.  The clone guard is handled
 *   by `sim_dev_update()` before this function is called; no need to repeat it.
 *
 * @param dev  SimDev instance — `cfg` and `state` must not be nullptr.
 * @param bus  Shared ComBus — `inCh` read, `outCh` + optional digital written.
 * @param ctx  Caller-supplied context snapshot for this cycle.
 */
void sim_traction_update(SimDev* dev, ComBus& bus, const SimDevCtx& ctx);

// EOF sim_traction.h
