/******************************************************************************
 * @file  sim_brake.h
 * @brief SimDev behaviour — analog brake axis (trigger deceleration).
 *
 * @details `sim_brake_update()` implements a proportional brake pedal:
 *   - Reads `inCh` (BRAKE_BUS) — trigger value in ComBus domain (0–CbusMaxVal).
 *   - If brake input exceeds `SimBrakeCfg::deadband`, ramps `outCh`
 *     (ESC_SPEED_BUS) toward CbusNeutral at a rate proportional to the
 *     brake pressure.
 *   - Writes `outCh` only when actively braking.  When brake is released
 *     (input ≤ deadband) or the vehicle is already stopped (outCh == CbusNeutral),
 *     the function returns without writing — the clone guard stays transparent
 *     and a downstream `sim_traction` SimDev runs normally.
 *
 *   **Array placement:** this SimDev must have a lower index than `sim_traction`
 *   in the `simDev[]` array.  When the trigger is active, `sim_brake_update()` writes
 *   `outCh` and sets `isDrived = true`, preventing `sim_traction` from
 *   overwriting the braked position.
 *
 *   Assign this function to `SimDev::behaviorFn` in the machine config:
 *   @code
 *     SimDev kMyDev = { ..., .behaviorFn = sim_brake_update };
 *   @endcode
 *****************************************************************************/
#pragma once

#include <struct/machines_struct.h>   // SimDev, SimBrakeCfg, SimBrakeState, SimBehaviorFn
#include <struct/combus_struct.h>     // ComBus

// Forward declaration — full type defined in sim_dev.h.
struct SimDevCtx;


// =============================================================================
// 1. PUBLIC API
// =============================================================================

/**
 * @brief Analog brake behaviour — assigned to `SimDev::behaviorFn`.
 *
 * @details Matches the `SimBehaviorFn` signature.  The clone guard is handled
 *   by `sim_dev_update()` before this function is called; no need to repeat it.
 *
 * @param dev  SimDev instance — `cfg` and `state` must not be nullptr.
 * @param bus  Shared ComBus — `inCh` read; `outCh` written only when brake is active.
 * @param ctx  Caller-supplied context — not used by this behaviour.
 */
void sim_brake_update(SimDev* dev, ComBus& bus, const SimDevCtx& ctx);

// EOF sim_brake.h
