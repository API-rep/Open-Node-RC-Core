/******************************************************************************
 * @file  sim_gear.cpp
 * @brief SimDev behaviour — speed-based virtual gear FSM (implementation).
 *
 * @details Pure ComBus processor — no hardware calls, no µs domain.
 *   Reads position from `inCh` (0–CbusMaxVal), converts to RPM, runs the
 *   gear FSM primitives (`sim_gear_fsm_init` / `sim_gear_fsm_update`),
 *   writes gear (1–N) to `outCh`.
 *
 *   The FSM primitives are also part of the public API (declared in sim_gear.h)
 *   for callers that need to force-reset a running FSM (e.g. on runlevel change).
 *   Self-init: on first call (`state->gear == 0`), FSM resets itself to gear 1.
 *****************************************************************************/

#include "sim_gear.h"
#include "sim_dev.h"         // SimDevCtx (full type — unused but required by SimBehaviorFn)

#include "core/system/combus/combus_res.h"    // CbusNeutral, CbusMaxVal
#include "core/system/combus/combus_access.h" // combus_set_analog

#include <Arduino.h>   // millis()


// =============================================================================
// 1. FSM PRIMITIVES
// =============================================================================

/** @brief Reset a `GearFsmState` to gear 1, clear shift guard and sub-gear. */
void sim_gear_fsm_init(GearFsmState* state)
{
    state->gear        = 1;
    state->prevRpm     = 0;
    state->lastShiftMs = 0u;
    state->subGear     = 0;
    state->prevSubGearSet = false;
    state->prevSubGearUp  = false;
    state->prevSubGearDn  = false;
}

/**
 * @brief Update speed-based N-gear FSM.
 *
 * @details Rising RPM trend → possible upshift; falling → downshift with
 *   braking thresholds. `rpm <= 0` forces gear 1. Guard timer prevents hunting.
 */
int8_t sim_gear_fsm_update(GearFsmState*           state,
                           const GearShiftProfile& profile,
                           int16_t                 rpm)
{
      // Reverse or standing: force gear 1.
    if (rpm <= 0) {
        state->gear    = 1;
        state->prevRpm = rpm;
        return state->gear;
    }

    const uint32_t now          = millis();
    const uint32_t shiftGuard   = now - state->lastShiftMs;
    const bool     decelerating = (rpm < state->prevRpm);

      // Upshift: RPM above threshold, not decelerating, guard elapsed.
    if (state->gear < static_cast<int8_t>(profile.gears)
        && rpm          > profile.upShift[state->gear - 1]
        && !decelerating
        && shiftGuard   > profile.shiftGuardMs)
    {
        state->gear++;
        state->lastShiftMs = now;
    }
      // Downshift: RPM below hysteresis threshold, guard elapsed.
    //   Use the braking (higher) threshold when decelerating — earlier downshift.
    else if (state->gear > 1 && shiftGuard > profile.shiftGuardMs)
    {
        const int16_t threshold = decelerating
                                ? profile.downShiftBraking[state->gear - 1]
                                : profile.downShift[state->gear - 1];
        if (rpm < threshold) {
            state->gear--;
            state->lastShiftMs = now;
        }
    }

    state->prevRpm = rpm;
    return state->gear;
}


// =============================================================================
// 2. BEHAVIOUR FUNCTION
// =============================================================================

/** @brief Gear FSM behaviour — see sim_gear.h for full contract. */
void sim_gear_update(SimDev* dev, ComBus& bus, const SimDevCtx& /* ctx */)
{
    const GearSimCfg* cfg   = static_cast<const GearSimCfg*>(dev->cfg);
    GearFsmState*     state = static_cast<GearFsmState*>(dev->state);

    // --- 0. Self-init on first call (gear == 0 = zero-initialised state) -----
    if (state->gear == 0) {
        sim_gear_fsm_init(state);
    }

    // --- 1. Read traction position from inCh -------------------------------------
    const uint16_t pos = bus.analogBus[static_cast<uint8_t>(dev->inCh)].value;

    // --- 2. Convert position to RPM (same scale as GearShiftProfile thresholds) --
    //    Absolute deviation from neutral → 0 at stand, maxRpm at full output.
    const int32_t dev_pos = (pos >= CbusNeutral)
                           ? static_cast<int32_t>(pos - CbusNeutral)
                           : static_cast<int32_t>(CbusNeutral - pos);
    const int16_t rpm = static_cast<int16_t>(
        dev_pos * static_cast<int32_t>(cfg->profile->maxRpm) / static_cast<int32_t>(CbusNeutral));

    // --- 3. Run gear FSM --------------------------------------------------------
    //    effectiveGear may be overridden to 1 below when sub-gear is active.
    int8_t gear = sim_gear_fsm_update(state, *cfg->profile, rpm);

    // --- 4. Write gear to outCh -------------------------------------------------
    combus_set_analog(bus, dev->outCh, static_cast<uint16_t>(gear), dev->chanOwner);

    // --- 5. Write per-gear ramp time to TRACTION_RAMP_BUS ----------------------
    //    Sub-gear mode: if active (subGear > 0) and in gear 1, use the sub-gear
    //    ramp table instead — much longer period = very slow crawl.
    //    Sub-gear FSM: SUBGEAR_SET rising edge toggles mode; SUBGEAR_UP / _DOWN
    //    rising edges step the sub-gear index (clamp 1..N, wraps at limits).
    //    Sub-gear is deactivated automatically when gear rises above 1.
    if (cfg->profile->subGearCount > 0u)
    {
        const bool setNow = bus.digitalBus[static_cast<uint8_t>(DigitalComBusID::SUBGEAR_SET)].value;
        const bool upNow  = bus.digitalBus[static_cast<uint8_t>(DigitalComBusID::SUBGEAR_UP)].value;
        const bool dnNow  = bus.digitalBus[static_cast<uint8_t>(DigitalComBusID::SUBGEAR_DOWN)].value;

          // Toggle on rising edge of SUBGEAR_SET.
        if (setNow && !state->prevSubGearSet) {
            state->subGear = (state->subGear == 0) ? 1 : 0;
        }

          // Step up on rising edge (higher index = faster crawl).
        if (state->subGear > 0 && upNow && !state->prevSubGearUp) {
            if (state->subGear < static_cast<int8_t>(cfg->profile->subGearCount))
                state->subGear++;
        }

          // Step down on rising edge (lower index = slower crawl).
        if (state->subGear > 0 && dnNow && !state->prevSubGearDn) {
            if (state->subGear > 1)
                state->subGear--;
        }

          // Sub-gear active: block FSM at gear 1 — prevent upshift while in crawler mode.
          // The driver must explicitly deactivate SUBGEAR_SET before the gearbox can rise.
        if (state->subGear > 0 && gear > 1)
            gear = 1;

        state->prevSubGearSet = setNow;
        state->prevSubGearUp  = upNow;
        state->prevSubGearDn  = dnNow;
    }

      // Write SUBGEAR_BUS (0 = inactive, 1..N = active sub-gear).
    combus_set_analog(bus, AnalogComBusID::SUBGEAR_BUS,
                      static_cast<uint16_t>(state->subGear), dev->chanOwner);

    if (cfg->profile->rampTime != nullptr)
    {
          // Sub-gear active: gear is locked at 1 (enforced above), so override
          // TRACTION_RAMP_BUS with the sub-gear ramp table.
        if (state->subGear > 0 && cfg->profile->subGearRampTime != nullptr)
        {
            const uint8_t sidx = static_cast<uint8_t>(
                constrain(static_cast<int>(state->subGear) - 1, 0,
                          static_cast<int>(cfg->profile->subGearCount) - 1));
            combus_set_analog(bus, AnalogComBusID::TRACTION_RAMP_BUS,
                              cfg->profile->subGearRampTime[sidx], dev->chanOwner);
        }
        else
        {
            const uint8_t idx = static_cast<uint8_t>(
                constrain(static_cast<int>(gear) - 1, 0,
                          static_cast<int>(cfg->profile->gears) - 1));
            combus_set_analog(bus, AnalogComBusID::TRACTION_RAMP_BUS,
                              cfg->profile->rampTime[idx], dev->chanOwner);
        }
    }
}

// EOF sim_gear.cpp
